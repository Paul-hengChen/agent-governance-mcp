    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.10.0"
  },
  "overrides": {
    "protobufjs": "^7.5.8",
    "qs": "^6.15.2"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
