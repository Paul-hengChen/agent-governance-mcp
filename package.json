{
  "name": "agent-governance-mcp",
  "version": "3.71.0",
  "description": "Agent Governance MCP — methodology-agnostic state sync, drift detection, and constitution enforcement for AI coding agents across multiple IDEs and sessions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-governance-mcp": "./dist/index.js",
    "agent-governance-context": "./bin/agent-governance-context.mjs",
    "agc": "./bin/agc-init.mjs"
  },
  "scripts": {
    "check:version": "node scripts/check-version.mjs",
    "prebuild": "npm run check:version",
    "build": "tsc",
    "start": "node dist/index.js",
    "pretest": "npm run build",
    "test": "node --test test/*.test.mjs",
    "eval": "node test/eval/run-eval.mjs"
